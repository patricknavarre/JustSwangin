# Local: copy to .env.local
# Vercel: Project → Settings → Environment Variables (Production / Preview / Development)

ANTHROPIC_API_KEY=sk-ant-...
# Optional: model id (default claude-haiku-4-5). Older 3.5 snapshot ids often 404.
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Vercel Blob — create a store in the Vercel dashboard (Storage → Blob) and add the read/write token here.
# Optional: swing analysis works without it (browser-only); only POST /api/upload needs this.
BLOB_READ_WRITE_TOKEN=

NEXT_PUBLIC_MAX_VIDEO_MB=100
